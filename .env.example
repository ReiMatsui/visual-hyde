# Visual HyDE Configuration
# Copy this file to .env and fill in your API keys.
#
# 最小構成（OpenAI のみ）:
#   VH_GEN_LLM_PROVIDER=openai
#   VH_GEN_OPENAI_API_KEY=sk-...
#
# 最小構成（Anthropic のみ）:
#   VH_GEN_LLM_PROVIDER=anthropic
#   VH_GEN_ANTHROPIC_API_KEY=sk-ant-...

# ── HuggingFace ────────────────────────────────────────────────────────────
# ViDoRe V2 など認証が必要なデータセットにアクセスする場合は設定する。
# トークンの取得: https://huggingface.co/settings/tokens
HF_TOKEN=hf_...

# ── Embedding Model ────────────────────────────────────────────────────────
# open-clip-torch で使用するモデル。変更は不要なことが多い。
# Options: openai/clip-vit-base-patch32 | openai/clip-vit-large-patch14
#          google/siglip-base-patch16-224 | google/siglip-so400m-patch14-384
VH_EMBED_MODEL=openai/clip-vit-large-patch14
VH_EMBED_BATCH_SIZE=32
VH_EMBED_DEVICE=cpu      # cpu | cuda | mps

# ── LLM Provider ──────────────────────────────────────────────────────────
# VLMを使う処理（matplotlibコード生成・TCD-HyDE記述生成）のプロバイダー。
# anthropic または openai を指定する。
VH_GEN_LLM_PROVIDER=openai    # anthropic | openai

# ── OpenAI API ────────────────────────────────────────────────────────────
VH_GEN_OPENAI_API_KEY=sk-...
VH_GEN_OPENAI_MODEL=gpt-4o    # gpt-4o | gpt-4-turbo | gpt-3.5-turbo など
# Azure OpenAI やローカルサーバー（Ollama, vLLM など）を使う場合は設定する
# VH_GEN_OPENAI_BASE_URL=https://your-resource.openai.azure.com/

# ── Anthropic API ─────────────────────────────────────────────────────────
VH_GEN_ANTHROPIC_API_KEY=sk-ant-...
VH_GEN_ANTHROPIC_MODEL=claude-opus-4-6

# ── Chart Generation ───────────────────────────────────────────────────────
VH_GEN_METHOD=matplotlib        # matplotlib | nano_banana
VH_GEN_MAX_CODE_TOKENS=1024
VH_GEN_GENERATION_TIMEOUT_S=30

# Pattern B: Nano Banana / Gemini（画像生成モデルを使う場合）
VH_GEN_GEMINI_API_KEY=AIza...
VH_GEN_IMAGE_GEN_MODEL=gemini-2.0-flash-preview-image-generation

# ── Retrieval ──────────────────────────────────────────────────────────────
VH_RETR_TOP_K=10
VH_RETR_ALPHA=0.5    # RRF hybrid weight (0=text-only, 1=visual-only)
VH_RETR_RRF_K=60     # RRF smoothing constant

# ── Evaluation ─────────────────────────────────────────────────────────────
VH_EVAL_MRR_K=10
